# Google Analytics 4 measurement ID (Admin > Data streams > Web stream details).
# Leave unset locally — analytics only loads when this is present.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional. Web3Forms access key for contact / start-project submissions.
# lib/enquiry.ts already hardcodes the live key (Web3Forms keys are public by
# design), so only set this to override it after a rotation.
NEXT_PUBLIC_WEB3FORMS_KEY=
